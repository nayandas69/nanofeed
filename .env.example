# =============================================================
# NanoFeed — Environment Variables
# Copy this file to `.env` and fill in the values
# =============================================================

# ── Database ──────────────────────────────────────────────────
# DATABASE_URL: The connection string to your PostgreSQL database.
# How to get it:
# 1. Local: If you have Postgres installed locally, it usually looks like:
#    postgresql://postgres:password@localhost:5432/nanofeed?schema=public
# 2. Cloud: Neon (Recommended for Vercel):
#    - Use the "Pooled connection" string from Neon for Vercel/Serverless.
#    - It usually ends with `-pooler` in the hostname.
#    - Example: postgresql://user:pass@ep-cool-db-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/nanofeed?schema=public"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────
# AUTH_SECRET: A random 32-character string used to encrypt session tokens.
# How to get it:
# - Run `npx auth secret` in your terminal
# - OR run `openssl rand -base64 32` in your terminal
# - OR generate a random 32-character string using a password manager.
AUTH_SECRET="your-super-secret-key-change-this-in-production"

# AUTH_GITHUB_ID & AUTH_GITHUB_SECRET: Credentials for GitHub OAuth login.
# How to get them:
# 1. Login to GitHub and go to Settings -> Developer Settings -> OAuth Apps
#    (Direct link: https://github.com/settings/developers)
# 2. Click "New OAuth App".
# 3. Fill in the details:
#    - Application name: NanoFeed (or your preferred name)
#    - Homepage URL: http://localhost:3000 (for local dev) or your prod domain.
#    - Authorization callback URL: http://localhost:3000/api/auth/callback/github
# 4. Click "Register application".
# 5. Copy the "Client ID". This is your AUTH_GITHUB_ID.
# 6. Click "Generate a new client secret" and copy it. This is your AUTH_GITHUB_SECRET.
AUTH_GITHUB_ID="your-github-oauth-app-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-client-secret"

# ── App Configuration ─────────────────────────────────────────
# NUXT_PUBLIC_APP_URL: The base URL of your application.
# How to get it:
# - For local development, leave it as http://localhost:3000
# - For production, use your actual domain (e.g., https://nanofeed.app)
NUXT_PUBLIC_APP_URL="http://localhost:3000"

# OWNER_GITHUB_ID: The numeric GitHub ID of the admin/owner.
# How to get it:
# 1. Go to https://api.github.com/users/YOUR_GITHUB_USERNAME in your browser.
# 2. Look for the "id" field in the JSON response (it's a number, e.g., 12345678).
# 3. Copy that number here. 
# This specific user will automatically be granted the 'OWNER' role on first login.
OWNER_GITHUB_ID="your-github-numeric-id"

# OWNER_GITHUB_USERNAME: Your GitHub username (used for database seeding).
# How to get it:
# - Just your regular GitHub username (e.g., torvalds).
OWNER_GITHUB_USERNAME="your-github-username"
