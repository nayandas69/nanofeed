# Nuxt build artifacts
.nuxt
.output
.vercel
dist

# Env files — never commit real secrets
.env
.env.*
!.env.example

# Node modules
node_modules

# Prisma generated client (regenerated via `prisma generate`)
# prisma/migrations are committed — but NOT the db push artifacts

# OS files
.DS_Store
Thumbs.db

# Editor settings
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Nuxt devtools
.nuxtrc

# TypeScript build info
*.tsbuildinfo
